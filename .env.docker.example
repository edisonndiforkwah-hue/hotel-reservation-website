APP_NAME="Hotel Project"
APP_ENV=production
APP_KEY=
APP_DEBUG=false

# Your public domain (required for HTTPS)
DOMAIN=hotel.example.com
APP_URL=https://hotel.example.com

# Let's Encrypt contact email (required for production HTTPS)
ACME_EMAIL=admin@example.com

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=hotel_db
DB_USERNAME=hotel_user
DB_PASSWORD=hotel_secret

MYSQL_ROOT_PASSWORD=root_secret
MYSQL_PORT=3306

SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

LOG_LEVEL=error
